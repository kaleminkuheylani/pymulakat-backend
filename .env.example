# ═══════════════════════════════════════════════════════════════
# PythonMulakat Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyala ve gerçek değerleri doldur.
# Asla gerçek .env dosyasını commit etme!
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (DB + Auth) ──────────────────────────────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key-DO-NOT-EXPOSE...

# JWT verification (auth.py) — Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── CORS ───────────────────────────────────────────────────
# Virgülle ayrılmış origin listesi (wildcard yok, env-driven explicit allow-list)
ALLOWED_ORIGINS=https://www.pythonmulakat.com,https://pythonmulakat.com,https://pymulakat-frontend.vercel.app,http://localhost:3000
# Vercel preview deploy'larına izin ver (/https://.*.vercel.app/)
ALLOW_VERCEL_PREVIEW=1

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=WARNING
LOG_FORMAT=json  # json | plain

# ─── App env ────────────────────────────────────────────────
APP_ENV=development  # development | production
# Production'da SUPABASE_JWT_SECRET zorunlu (auth.py fail-fast)

# ─── Cache (question_loader.py) ─────────────────────────────
# Per-filter in-memory cache TTL (saniye). Yeni soru eklenince
# /admin/invalidate-cache ile manuel sıfırlanabilir, ya da on-demand
# revalidation Next.js tarafında webhook ile tetiklenir.
QUESTION_CACHE_TTL=60

# ─── Admin endpoint güvenliği ───────────────────────────────
# /admin/* endpoint'leri X-Admin-Secret header'ı ile korunur
# (programatik backend-to-backend admin API'leri icin)
ADMIN_SECRET=replace-with-strong-random-hex

# Admin session JWT (admin_auth.py) — login sonrasi session cookie imzalama
# /admin/login → email+password → session JWT (8 saat) → HttpOnly cookie
# Default kullanilirsa sadece WARNING log'lar, production'da MUTLAKA set edilmeli
# 32-byte random hex: openssl rand -hex 32
ADMIN_JWT_SECRET=replace-with-strong-random-hex-32-byte-DIFFERENT-from-ADMIN-SECRET

# ─── Next.js ISR revalidation webhook (2026-07-13) ──────────
# İçerik güncellendiğinde (yeni soru, kategori değişikliği) Next.js
# /api/revalidate endpoint'ine POST atılır. Frontend ve backend aynı
# secret'ı paylaşır.
#
# NEXTJS_REVALIDATE_URL: Next.js app URL + /api/revalidate
# REVALIDATE_SECRET:     frontend app/api/revalidate/route.ts ile aynı değer
#
# Local dev'de: NEXTJS_REVALIDATE_URL=http://localhost:3000/api/revalidate
# Production:   NEXTJS_REVALIDATE_URL=https://pythonmulakat.com/api/revalidate
NEXTJS_REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=replace-with-strong-random-32-byte-hex

# ─── Email (Resend) ─────────────────────────────────────────
# Doğrulama kodu ve reset password
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=mkemal@pythonmulakat.com
