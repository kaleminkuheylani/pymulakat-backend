# ═══════════════════════════════════════════════════════════════
# PythonMulakat Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyala ve gerçek değerleri doldur.
# Asla gerçek .env dosyasını commit etme!
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────
# Aynı proje, hem frontend hem backend aynı URL'i kullanır
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...anon-key...

# ⚠️ SERVICE_ROLE_KEY backend-only'dir, ASLA frontend'e verme!
# Supabase Dashboard → Settings → API → service_role (gizli)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key...

# ─── AI Services ───────────────────────────────────────────
# Soru üretimi + değerlendirme için (services/gemini.py kullanıyor)
GEMINI_API_KEY=AIzaSy...your-gemini-key...

# ─── Email (Resend) ────────────────────────────────────────
# Doğrulama kodu gönderimi için
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=mkemal@pythonmulakat.com

# ─── App Config ────────────────────────────────────────────
APP_ENV=development                    # development | production
DEBUG=true
CORS_ORIGINS=http://localhost:3000,https://pythonmulakat.com

# ─── Cron (Otomatik Soru Uretimi) ───────────────────────────
# /admin/cron/run-question-generation endpoint'ini korur.
# Railway veya external cron service tarafindan kullanilacak.
# Ornek: her Pazartesi 09:00
#   curl -X POST $API_URL/admin/cron/run-question-generation -H "X-Cron-Secret: $CRON_SECRET"
CRON_SECRET=change-me-to-random-string

# ─── Supabase SQL Schema (Dashboard → SQL Editor'da çalıştır) ─
#
# profiles tablosu:
#   ALTER TABLE profiles ADD COLUMN IF NOT EXISTS is_verified BOOLEAN DEFAULT FALSE;
#   ALTER TABLE profiles ADD COLUMN IF NOT EXISTS verification_code TEXT;
#   ALTER TABLE profiles ADD COLUMN IF NOT EXISTS verification_code_expires_at TIMESTAMPTZ;
#
# interview_attempts tablosu:
#   CREATE TABLE interview_attempts (
#     id BIGSERIAL PRIMARY KEY,
#     user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,
#     question_id INT NOT NULL,
#     passed_tests INT NOT NULL DEFAULT 0,
#     total_tests INT NOT NULL DEFAULT 0,
#     success BOOLEAN NOT NULL DEFAULT FALSE,
#     execution_time_ms INT NOT NULL DEFAULT 0,
#     hints_used INT NOT NULL DEFAULT 0,
#     user_code TEXT,
#     created_at TIMESTAMPTZ DEFAULT NOW()
#   );
#
#   CREATE INDEX idx_attempts_user_id ON interview_attempts(user_id);
#   CREATE INDEX idx_attempts_question_id ON interview_attempts(question_id);